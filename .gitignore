# ============================================================
# .gitignore — CryptoTrivia DApp on Canopy Network
# ============================================================

# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Build Output ───────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.vite/

# ─── Environment Variables ──────────────────────────────────
# Never commit private keys or RPC secrets
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# ─── Canopy Node / Wallet Secrets ───────────────────────────
# NEVER commit wallet keys or node credentials
*.pem
*.key
*.keystore
wallet.json
keystore/
canopy-node-config.local.*
node-data/
chain-data/

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Testing ────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── Cache ──────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
.rollup.cache/

# ─── OS Files ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editor / IDE ───────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ─── Package Manager Locks (keep only one) ──────────────────
# Uncomment the one you are NOT using:
# package-lock.json   # if using yarn
# yarn.lock           # if using npm
# pnpm-lock.yaml      # if using npm or yarn

# ─── Misc ───────────────────────────────────────────────────
*.local
.vercel
.netlify
*.zip
*.tar.gz
tmp/
temp/

